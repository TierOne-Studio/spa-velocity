{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push * main:*)",
      "Bash(git push * master:*)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push * *:main)",
      "Bash(git push * *:master)",
      "Bash(git push * :main)",
      "Bash(git push * :master)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Bash(git push -u origin main:*)",
      "Bash(git push -u origin master:*)",
      "Bash(git push -u origin main)",
      "Bash(git push -u origin master)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git rebase -i main:*)",
      "Bash(git rebase -i master:*)",
      "Bash(git rebase -i main)",
      "Bash(git rebase -i master)",
      "Bash(git rebase --root:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(npm publish:*)",
      "Bash(npm publish)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(vercel deploy:*)",
      "Bash(vercel --prod:*)",
      "Bash(netlify deploy:*)",
      "Bash(netlify deploy --prod:*)",
      "Bash(gh-pages -d:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(npm version:*)",
      "Bash(npm install --save:*)",
      "Bash(npm install -S:*)",
      "Bash(npm install --save-dev:*)",
      "Bash(npm install -D:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm rm:*)",
      "Bash(rm -rf:*)"
    ],
    "allow": [
      "Bash(echo \"API PID: $!\")",
      "Bash(npx vite:*)",
      "Bash(echo \"FE PID: $!\")",
      "Read(//private/tmp/**)",
      "Bash(curl -s http://127.0.0.1:3000/health)",
      "Bash(pkill -f \"vite preview --port 4173\")",
      "Bash(npx playwright:*)",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test e2e/auth.spec.ts --grep \"should successfully login with verified user\")",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test e2e/champion-velocity-flow.spec.ts e2e/organization-collection-chat-flow.spec.ts)",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test e2e/champion-velocity-flow.spec.ts)",
      "Bash(git checkout:*)",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test e2e/guards.spec.ts e2e/rbac-unified-roles.spec.ts e2e/rbac-impersonation.spec.ts)",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test e2e/rbac-impersonation.spec.ts --grep \"should allow platform admin to create organization\")",
      "Bash(E2E_REUSE_EXISTING_SERVER=false E2E_API_BASE_URL=http://127.0.0.1:3100 E2E_FE_URL=http://127.0.0.1:4173 npx playwright test)",
      "Bash(ls -d /Users/mravinale/Repositories/Github/spa-velocity/src/features/*/)",
      "Bash(git fetch:*)",
      "Bash(git commit -m ':*)",
      "Bash(git clean:*)",
      "Bash(git branch:*)",
      "Bash(git reset:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(git commit --allow-empty -m ':*)",
      "Bash(grep -E \"\\\\.\\(ts|tsx\\)$\")",
      "Bash(ls -la /Users/mravinale/Repositories/Github/spa-velocity/*.md)"
    ]
  }
}
